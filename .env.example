# === Application ===
APP_NAME="Parking Intelligence & Enforcement Platform"
DEBUG=true
SECRET_KEY=change-this-to-a-random-secret-key-in-production

# === Database ===
# SQLite (default, no setup required)
DATABASE_URL=sqlite:///./parking_enforcement.db
# PostgreSQL (production recommended)
# DATABASE_URL=postgresql://parkiq:password@localhost:5432/parkiq

# === ML / AI ===
# Set to true to use simulated detections (no GPU/model required)
SIMULATE_DETECTIONS=true
YOLO_MODEL_PATH=yolov8n.pt
YOLO_CONFIDENCE=0.4

# === Claude AI (optional — enables AI report generation) ===
ANTHROPIC_API_KEY=your-anthropic-api-key-here
CLAUDE_MODEL=claude-sonnet-4-6
CLAUDE_MAX_TOKENS=2048

# === Storage ===
STORAGE_BACKEND=local
LOCAL_STORAGE_PATH=./storage

# === Redis (optional — for WebSocket pub/sub at scale) ===
REDIS_ENABLED=false
REDIS_URL=redis://localhost:6379

# === CORS ===
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
